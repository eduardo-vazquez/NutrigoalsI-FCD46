      <Association Name="Usuario_AlimentoIngerido" Member="AlimentoIngeridos" ThisKey="IdUsuario" OtherKey="FKIdUsuario" Type="AlimentoIngerido" />
    </Type>
  </Table>
  <Table Name="dbo.ObjetivosNutricionales" Member="ObjetivosNutricionales">
    <Type Name="ObjetivosNutricionale">
      <Column Name="IdObjetivoNutricional" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
      <Column Name="FKIdUsuario" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="FechaDeEstablecimiento" Type="System.DateTime" DbType="Date NOT NULL" CanBeNull="false" />
      <Column Name="CaloriasDiaObjetivo" Type="System.Decimal" DbType="Decimal(10,2) NOT NULL" CanBeNull="false" />
      <Column Name="ProteinasDiaObjetivo" Type="System.Decimal" DbType="Decimal(10,2) NOT NULL" CanBeNull="false" />
      <Column Name="CarbohidratosDiaObjetivo" Type="System.Decimal" DbType="Decimal(10,2) NOT NULL" CanBeNull="false" />
      <Column Name="GrasasDiaObjetivo" Type="System.Decimal" DbType="Decimal(10,2) NOT NULL" CanBeNull="false" />
      <Column Name="Objetivo" Type="System.String" DbType="VarChar(10)" CanBeNull="true" />
      <Association Name="Usuario_ObjetivosNutricionale" Member="Usuario" ThisKey="FKIdUsuario" OtherKey="IdUsuario" Type="Usuario" IsForeignKey="true" />
    </Type>
  </Table>
  <Table Name="dbo.UserMetrica" Member="UserMetricas">
    <Type Name="UserMetrica">
      <Column Name="IdMetrica" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
