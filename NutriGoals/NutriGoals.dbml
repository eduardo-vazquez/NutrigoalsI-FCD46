      <Column Name="Sexo" Type="System.Char" DbType="Char(1)" CanBeNull="true" />
      <Column Name="NivelDeActividad" Type="System.Int32" DbType="Int" CanBeNull="true" />
      <Association Name="Usuario_UserMetrica" Member="Usuario" ThisKey="FKIdUsuario" OtherKey="IdUsuario" Type="Usuario" IsForeignKey="true" />
    </Type>
  </Table>
  <Table Name="dbo.Alimento" Member="Alimentos">
    <Type Name="Alimento">
      <Column Name="IdAlimento" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
      <Column Name="Nombre" Type="System.String" DbType="VarChar(100) NOT NULL" CanBeNull="false" />
      <Column Name="Calorias100" Type="System.Decimal" DbType="Decimal(8,2) NOT NULL" CanBeNull="false" />
