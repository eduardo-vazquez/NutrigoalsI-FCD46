      <Column Name="FKIdUsuario" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="FKIdAlimento" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="FechaHoraConsumo" Type="System.DateTime" DbType="DateTime NOT NULL" CanBeNull="false" />
      <Column Name="CantidadGramos" Type="System.Decimal" DbType="Decimal(8,0) NOT NULL" CanBeNull="false" />
